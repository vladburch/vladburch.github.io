---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter(h => h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <aside class="toc">
    <div class="toc-title">On this page</div>
    <nav class="toc-nav">
      {filteredHeadings.map(heading => (
        <a
          href={`#${heading.slug}`}
          class:list={['toc-link', { sub: heading.depth === 3 }]}
        >
          {heading.text}
        </a>
      ))}
    </nav>
  </aside>
)}

<style>
  .toc {
    width: 200px;
    flex-shrink: 0;
    position: sticky;
    top: 24px;
    align-self: flex-start;
  }

  .toc-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .toc-nav {
    display: flex;
    flex-direction: column;
  }

  .toc-link {
    font-size: 12px;
    color: var(--text-dim);
    padding: 4px 0 4px 12px;
    border-left: 1px solid rgba(14, 165, 233, 0.08);
    transition: all 0.25s ease;
    line-height: 1.4;
  }

  .toc-link:hover {
    color: var(--accent);
    border-left-color: var(--accent);
  }

  .toc-link.sub {
    padding-left: 24px;
    font-size: 11px;
    color: var(--text-dim);
  }

  .toc-link.sub:hover {
    color: var(--accent);
    border-left-color: var(--accent);
  }
</style>
