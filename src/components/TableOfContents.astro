---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter(h => h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <aside class="toc">
    <div class="ff-eyebrow toc__title">On this page</div>
    <ol class="toc__list">
      {filteredHeadings.map(heading => (
        <li class:list={['toc__item', { 'toc__item--sub': heading.depth === 3 }]}>
          <a href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))}
    </ol>
  </aside>
)}

<style>
  .toc {
    padding: 16px;
    border: 1px solid var(--border-hair);
    border-radius: var(--r-3);
    background: var(--bg-2);
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 80px;
    align-self: flex-start;
  }

  .toc__title { margin-bottom: 10px; }

  .toc__list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: toc;
  }

  .toc__item {
    counter-increment: toc;
    font-size: var(--fs-sm);
    padding: 6px 0;
    border-bottom: 1px dashed var(--border-hair);
    color: var(--fg-2);
    display: flex;
    gap: 10px;
    align-items: baseline;
  }

  .toc__item::before {
    content: counter(toc, decimal-leading-zero);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--fg-3);
    letter-spacing: 0.1em;
    flex-shrink: 0;
  }

  .toc__item:last-child { border: 0; }

  .toc__item a {
    color: inherit;
    transition: color var(--dur-fast);
  }

  .toc__item a:hover { color: var(--fg-1); }

  .toc__item--sub { padding-left: 12px; font-size: 12px; }

  @media (max-width: 768px) {
    .toc { display: none; }
  }
</style>
