---
interface ArticleItem {
  href: string;
  title: string;
  meta: string;
}

interface Props {
  items: ArticleItem[];
}

const { items } = Astro.props;
---

<div class="article-list">
  {items.map(item => (
    <div class="article-row">
      <a href={item.href} class="article-link">{item.title}</a>
      <span class="article-meta">{item.meta}</span>
    </div>
  ))}
</div>

<style>
  .article-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .article-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid rgba(14, 165, 233, 0.04);
    transition: border-color 0.3s;
  }

  .article-row:last-child {
    border-bottom: none;
  }

  .article-row:hover {
    border-bottom-color: rgba(14, 165, 233, 0.1);
  }

  .article-meta {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--text-dim);
    white-space: nowrap;
    margin-left: 16px;
    letter-spacing: 0.04em;
  }
</style>
