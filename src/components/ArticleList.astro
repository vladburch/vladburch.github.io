---
interface ArticleItem {
  href: string;
  title: string;
  meta: string;
}

interface Props {
  items: ArticleItem[];
}

const { items } = Astro.props;
---

<div class="article-list">
  {items.map(item => (
    <a href={item.href} class="article-row">
      <div class="article-row__body">
        <div class="article-row__meta">{item.meta}</div>
        <div class="article-row__title">{item.title}</div>
      </div>
      <span class="article-row__arrow">→</span>
    </a>
  ))}
</div>

<style>
  .article-list {
    border-top: 1px solid var(--border-hair);
  }

  .article-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border-hair);
    color: var(--fg-1);
    transition: background var(--dur-fast);
  }

  .article-row:hover { background: var(--bg-2); }

  .article-row__meta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-3);
    margin-bottom: 4px;
  }

  .article-row__title {
    font-size: var(--fs-base);
    font-weight: 500;
    line-height: 1.3;
  }

  .article-row__arrow {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--fg-3);
    flex-shrink: 0;
    transition: transform var(--dur-fast);
  }

  .article-row:hover .article-row__arrow {
    transform: translateX(3px);
    color: var(--fg-1);
  }
</style>
