---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/knowledge_base/', label: 'Knowledge Base' },
  { href: '/about/', label: 'About' },
];

function isActive(href: string): boolean {
  if (href === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(href);
}
---

<header class="header">
  <a href="/" class="logo">
    <span class="logo-mark"></span>
    Firewall Flamingos
  </a>
  <nav class="nav">
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={['nav-link', { active: isActive(link.href) }]}
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>

<style>
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 32px;
    border-bottom: 1px solid var(--border-subtle);
    position: relative;
    z-index: 10;
  }

  .logo {
    font-family: 'IBM Plex Sans', sans-serif;
    font-weight: 700;
    font-size: 15px;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .logo-mark {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 8px rgba(14, 165, 233, 0.4);
    animation: pulse-dot 3s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 8px rgba(14, 165, 233, 0.4); }
    50% { box-shadow: 0 0 14px rgba(14, 165, 233, 0.7); }
  }

  .nav {
    display: flex;
    gap: 28px;
  }

  .nav :global(.nav-link) {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    position: relative;
  }
</style>
