---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="tag-list">
  {tags.map(tag => (
    <a href={`/tags/${tag}/`} class="tag-chip" data-pagefind-filter="tag">{tag}</a>
  ))}
</div>

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }

  .tag-chip {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    padding: 3px 8px;
    border: 1px solid var(--border-1);
    border-radius: var(--r-1);
    color: var(--fg-3);
    transition: all var(--dur-fast);
  }

  .tag-chip:hover {
    border-color: var(--fg-1);
    color: var(--fg-1);
  }
</style>
