<div id="tsparticles"></div>

<script>
  import { tsParticles } from "@tsparticles/engine";
  import { loadSlim } from "@tsparticles/slim";

  async function initParticles() {
    await loadSlim(tsParticles);

    await tsParticles.load({
      id: "tsparticles",
      options: {
        fullScreen: false,
        fpsLimit: 60,
        particles: {
          color: { value: "#a855f7" },
          links: {
            color: "#a855f7",
            distance: 150,
            enable: true,
            opacity: 0.05,
            width: 1,
          },
          move: {
            enable: true,
            speed: 0.5,
            direction: "none",
            outModes: { default: "out" },
          },
          number: {
            density: { enable: true, area: 1200 },
            value: 35,
          },
          opacity: { value: { min: 0.1, max: 0.3 } },
          shape: { type: "circle" },
          size: { value: { min: 1, max: 3 } },
        },
        detectRetina: true,
      },
    });
  }

  initParticles();
</script>

<style>
  #tsparticles {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
</style>
