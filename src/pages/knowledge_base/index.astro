---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleList from '../../components/ArticleList.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('kb'))
  .sort((a, b) => b.data.lastUpdated.valueOf() - a.data.lastUpdated.valueOf());

const items = articles.map(article => ({
  href: `/knowledge_base/${article.id}/`,
  title: article.data.title,
  meta: article.data.tags[0],
}));
---

<BaseLayout title="Knowledge Base" description="Guides, cheat sheets, and quick references.">
  <section class="listing">
    <h1>Knowledge Base</h1>
    <p class="listing-desc">Guides, cheat sheets, and quick references.</p>
    <ArticleList items={items} />
  </section>
</BaseLayout>

<style>
  .listing {
    max-width: 640px;
    margin: 0 auto;
    padding: 48px 24px;
  }

  .listing h1 {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 4px;
    letter-spacing: -0.02em;
  }

  .listing-desc {
    color: var(--text-muted);
    font-size: 14px;
    margin-bottom: 24px;
  }
</style>
