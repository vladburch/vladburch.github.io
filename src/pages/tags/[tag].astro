---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  const kbArticles = await getCollection('kb');

  const tagMap = new Map<string, { blog: typeof blogPosts; kb: typeof kbArticles }>();

  for (const post of blogPosts) {
    for (const tag of post.data.tags) {
      if (!tagMap.has(tag)) tagMap.set(tag, { blog: [], kb: [] });
      tagMap.get(tag)!.blog.push(post);
    }
  }

  for (const article of kbArticles) {
    for (const tag of article.data.tags) {
      if (!tagMap.has(tag)) tagMap.set(tag, { blog: [], kb: [] });
      tagMap.get(tag)!.kb.push(article);
    }
  }

  return Array.from(tagMap.entries()).map(([tag, data]) => ({
    params: { tag },
    props: { tag, blogPosts: data.blog, kbArticles: data.kb },
  }));
}

const { tag, blogPosts, kbArticles } = Astro.props;

function formatDate(d: Date) {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${y}·${m}·${day}`;
}

const sortedBlog = blogPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const sortedKb = kbArticles.sort((a, b) => b.data.lastUpdated.valueOf() - a.data.lastUpdated.valueOf());

const total = sortedBlog.length + sortedKb.length;
---

<BaseLayout title={`Tag: ${tag}`} description={`Articles tagged with "${tag}".`}>
  <section class="tag-page container">
    <div class="ff-eyebrow" style="margin-bottom:16px">Tag</div>
    <h1 class="tag-title">{tag}</h1>
    <p class="tag-count">{total} article{total !== 1 ? 's' : ''}</p>

    {sortedBlog.length > 0 && (
      <div class="group">
        <div class="ff-eyebrow group__label">Blog</div>
        <div class="list__rows">
          {sortedBlog.map(post => (
            <a class="row" href={`/blog/${post.id}/`}>
              <div class="row__body">
                <div class="row__meta">
                  <span>{post.data.category.toUpperCase()}</span>
                  <span>·</span>
                  <span>{formatDate(post.data.date)}</span>
                </div>
                <div class="row__title">{post.data.title}</div>
              </div>
              <div class="row__arrow">→</div>
            </a>
          ))}
        </div>
      </div>
    )}

    {sortedKb.length > 0 && (
      <div class="group">
        <div class="ff-eyebrow group__label">Knowledge Base</div>
        <div class="list__rows">
          {sortedKb.map(article => (
            <a class="row" href={`/knowledge_base/${article.id}/`}>
              <div class="row__body">
                <div class="row__meta">
                  <span>KB</span>
                  <span>·</span>
                  <span>{formatDate(article.data.lastUpdated)}</span>
                </div>
                <div class="row__title">{article.data.title}</div>
              </div>
              <div class="row__arrow">→</div>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .tag-page {
    padding: 56px 28px 96px;
    max-width: 960px;
  }

  .tag-title {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: clamp(36px, 5vw, 60px);
    letter-spacing: -0.04em;
    margin: 0 0 8px;
    color: var(--fg-1);
  }

  .tag-count {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--fg-3);
    text-transform: uppercase;
    margin-bottom: 40px;
  }

  .group { margin-bottom: 48px; }

  .group__label { margin-bottom: 12px; }

  .list__rows { border-top: 1px solid var(--border-hair); }

  .row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 24px;
    padding: 18px 0;
    border-bottom: 1px solid var(--border-hair);
    transition: background var(--dur-fast);
    color: var(--fg-1);
  }

  .row:hover { background: var(--bg-2); }

  .row__meta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--fg-3);
    display: flex;
    gap: 8px;
    margin-bottom: 6px;
  }

  .row__title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 19px;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .row__arrow {
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--fg-3);
    transition: transform var(--dur-fast);
    flex-shrink: 0;
  }

  .row:hover .row__arrow {
    transform: translateX(4px);
    color: var(--fg-1);
  }

  @media (max-width: 700px) {
    .tag-page { padding: 32px 20px 64px; }
    .row__title { font-size: 16px; }
  }
</style>
