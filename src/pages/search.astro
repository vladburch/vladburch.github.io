---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
const kbArticles = await getCollection('kb');

const allTags = new Set<string>();
for (const post of blogPosts) post.data.tags.forEach(t => allTags.add(t));
for (const article of kbArticles) article.data.tags.forEach(t => allTags.add(t));
const sortedTags = Array.from(allTags).sort();

const fallbackIndex = [
  ...blogPosts.map(post => ({
    url: `/blog/${post.id}/`,
    title: post.data.title,
    description: post.data.description,
    section: 'Blog',
    tags: post.data.tags,
  })),
  ...kbArticles.map(article => ({
    url: `/knowledge_base/${article.id}/`,
    title: article.data.title,
    description: article.data.description,
    section: 'Knowledge Base',
    tags: article.data.tags,
  })),
];
---

<BaseLayout title="Search" description="Search articles, tags, and keywords.">
  <section class="search-page container">
    <div class="ff-eyebrow" style="margin-bottom:16px">Search</div>

    <div class="search-box">
      <span class="search-prompt">›</span>
      <input
        type="text"
        id="search-input"
        placeholder="search posts, CVEs, hashes…"
        autocomplete="off"
      />
    </div>

    <div class="filters">
      <div class="filter-row">
        <span class="filter-label">Section</span>
        <button class="chip is-on" data-section="all">All</button>
        <button class="chip" data-section="Blog">Blog</button>
        <button class="chip" data-section="KB">Knowledge Base</button>
      </div>
      <div class="filter-row filter-row--tags">
        <span class="filter-label">Tags</span>
        {sortedTags.map(tag => (
          <button class="chip chip--sm" data-tag={tag}>{tag}</button>
        ))}
      </div>
    </div>

    <div id="search-results" class="results">
      <p class="results-hint">Start typing to search…</p>
    </div>
  </section>

  <script is:inline define:vars={{ fallbackIndex }}>
    window.__searchIndex = fallbackIndex;
  </script>

  <script is:inline type="module">
    (async function() {
      var input = document.getElementById('search-input');
      var resultsContainer = document.getElementById('search-results');
      var sectionBtns = document.querySelectorAll('[data-section]');
      var tagBtns = document.querySelectorAll('[data-tag]');

      var pagefind = null;
      if (typeof WebAssembly === 'object') {
        try {
          pagefind = await import(new URL('/pagefind/pagefind.js', window.location.origin).href);
          await pagefind.init();
        } catch (e) {
          pagefind = null;
        }
      }

      var currentSection = 'all';
      var activeTags = new Set();

      sectionBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          sectionBtns.forEach(function(b) { b.classList.remove('is-on'); });
          btn.classList.add('is-on');
          currentSection = btn.dataset.section;
          performSearch();
        });
      });

      tagBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var tag = btn.dataset.tag;
          if (activeTags.has(tag)) {
            activeTags.delete(tag);
            btn.classList.remove('is-on');
          } else {
            activeTags.add(tag);
            btn.classList.add('is-on');
          }
          performSearch();
        });
      });

      function fallbackSearch(query) {
        var index = window.__searchIndex || [];
        var lower = query.toLowerCase();
        var words = lower.split(/\s+/).filter(function(w) { return w.length > 0; });
        var results = [];
        for (var i = 0; i < index.length; i++) {
          var item = index[i];
          if (currentSection !== 'all') {
            var wantSection = currentSection === 'KB' ? 'Knowledge Base' : currentSection;
            if (item.section !== wantSection) continue;
          }
          if (activeTags.size > 0) {
            var hasTag = false;
            for (var t = 0; t < item.tags.length; t++) {
              if (activeTags.has(item.tags[t])) { hasTag = true; break; }
            }
            if (!hasTag) continue;
          }
          var searchable = (item.title + ' ' + item.description + ' ' + item.tags.join(' ')).toLowerCase();
          var matched = true;
          for (var w = 0; w < words.length; w++) {
            if (searchable.indexOf(words[w]) === -1) { matched = false; break; }
          }
          if (matched) {
            var excerpt = item.description;
            for (var w = 0; w < words.length; w++) {
              var re = new RegExp('(' + words[w].replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
              excerpt = excerpt.replace(re, '<mark>$1</mark>');
            }
            results.push({ url: item.url, title: item.title, excerpt: excerpt });
          }
        }
        return results;
      }

      async function performSearch() {
        var query = input.value.trim();
        if (!query && activeTags.size === 0) {
          resultsContainer.innerHTML = '<p class="results-hint">Start typing to search…</p>';
          return;
        }

        var filtered;
        if (pagefind && query) {
          try {
            var searchFilters = {};
            if (currentSection !== 'all') searchFilters.section = [currentSection === 'KB' ? 'Knowledge Base' : currentSection];
            if (activeTags.size > 0) searchFilters.tag = Array.from(activeTags);
            var search = await pagefind.search(query, { filters: searchFilters });
            var data = await Promise.all(search.results.slice(0, 20).map(function(r) { return r.data(); }));
            filtered = data.map(function(r) { return { url: r.url, title: r.meta.title || r.url, excerpt: r.excerpt }; });
          } catch (e) {
            filtered = fallbackSearch(query);
          }
        } else {
          filtered = fallbackSearch(query);
        }

        if (filtered.length === 0) {
          resultsContainer.innerHTML = '<p class="results-hint">No results' + (query ? ' for “' + query + '”' : '') + '</p>';
          return;
        }

        resultsContainer.innerHTML =
          '<p class="results-count">' + filtered.length + ' result' + (filtered.length !== 1 ? 's' : '') + (query ? ' for “' + query + '”' : '') + '</p>' +
          filtered.map(function(r) {
            return '<a href="' + r.url + '" class="result-item">' +
              '<div class="result-title">' + r.title + '</div>' +
              '<p class="result-excerpt">' + r.excerpt + '</p>' +
              '<span class="result-arrow">→</span>' +
            '</a>';
          }).join('');
      }

      input.addEventListener('input', performSearch);

      var urlParams = new URLSearchParams(window.location.search);
      var initialQuery = urlParams.get('q');
      if (initialQuery) {
        input.value = initialQuery;
        performSearch();
      }
    })();
  </script>
</BaseLayout>

<style>
  .search-page {
    padding: 56px 28px 96px;
    max-width: 720px;
  }

  .search-box {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border: 1px solid var(--border-1);
    border-radius: var(--r-2);
    margin-bottom: 24px;
    transition: border-color var(--dur-fast);
  }

  .search-box:focus-within {
    border-color: var(--fg-1);
    outline: 2px solid var(--ff-signal);
    outline-offset: 2px;
  }

  .search-prompt {
    color: var(--fg-3);
    font-family: var(--font-mono);
    font-size: 16px;
    flex-shrink: 0;
  }

  #search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--fg-1);
  }

  #search-input::placeholder {
    color: var(--fg-3);
  }

  .filters {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 32px;
  }

  .filter-row {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .filter-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-3);
    margin-right: 4px;
    flex-shrink: 0;
  }

  .chip {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 6px 10px;
    border: 1px solid var(--border-1);
    border-radius: var(--r-pill);
    background: var(--bg-1);
    color: var(--fg-2);
    cursor: pointer;
    transition: all var(--dur-fast);
  }

  .chip:hover { border-color: var(--fg-1); color: var(--fg-1); }

  .chip.is-on {
    background: var(--fg-1);
    color: var(--bg-1);
    border-color: var(--fg-1);
  }

  .chip--sm { padding: 4px 8px; font-size: 10px; }

  .results-hint {
    color: var(--fg-3);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    letter-spacing: 0.04em;
  }

  :global(.results-count) {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--fg-3);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  :global(.result-item) {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 16px;
    padding: 18px 0;
    border-bottom: 1px solid var(--border-hair);
    color: var(--fg-1);
    transition: background var(--dur-fast);
  }

  :global(.result-item:hover) { background: var(--bg-2); }

  :global(.result-title) {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 19px;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }

  :global(.result-excerpt) {
    font-size: var(--fs-sm);
    color: var(--fg-2);
    line-height: 1.5;
  }

  :global(.result-arrow) {
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--fg-3);
    padding-top: 4px;
    transition: transform var(--dur-fast);
  }

  :global(.result-item:hover .result-arrow) {
    transform: translateX(4px);
    color: var(--fg-1);
  }

  :global(.result-excerpt mark) {
    background: rgba(217,255,59,0.25);
    color: var(--fg-1);
    padding: 0 2px;
    border-radius: var(--r-1);
  }

  @media (max-width: 700px) {
    .search-page {
      padding: 32px 20px 64px;
    }
  }
</style>
