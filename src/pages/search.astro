---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
const kbArticles = await getCollection('kb');

const allTags = new Set<string>();
for (const post of blogPosts) post.data.tags.forEach(t => allTags.add(t));
for (const article of kbArticles) article.data.tags.forEach(t => allTags.add(t));
const sortedTags = Array.from(allTags).sort();

---

<BaseLayout title="Search" description="Search articles, tags, and keywords.">
  <section class="search-page">
    <div class="search-bar">
      <div class="gradient-border">
        <div class="gradient-border-inner search-inner">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
          <input
            type="text"
            id="search-input"
            placeholder="Search articles, tags, keywords..."
            autocomplete="off"
          />
        </div>
      </div>
    </div>

    <div class="filters">
      <div class="section-filters">
        <span class="filter-label">Section:</span>
        <button class="filter-btn active" data-section="all">All</button>
        <button class="filter-btn" data-section="Blog">Blog</button>
        <button class="filter-btn" data-section="KB">Knowledge Base</button>
      </div>

      <div class="tag-filters">
        <span class="filter-label">Tags:</span>
        {sortedTags.map(tag => (
          <button class="tag-filter" data-tag={tag}>{tag}</button>
        ))}
      </div>
    </div>

    <div id="search-results" class="results">
      <p class="results-hint">Start typing to search...</p>
    </div>
  </section>

  <script is:inline type="module">
    const input = document.getElementById('search-input');
    const resultsContainer = document.getElementById('search-results');
    const sectionBtns = document.querySelectorAll('.filter-btn');
    const tagBtns = document.querySelectorAll('.tag-filter');

    let pagefind;
    try {
      pagefind = await import('/pagefind/pagefind.js');
      await pagefind.init();
    } catch (e) {
      resultsContainer.innerHTML = '<p class="results-hint">Search index not available. Run a production build first.</p>';
      console.error('Pagefind init error:', e);
    }

    if (pagefind) {
      let currentSection = 'all';
      let activeTags = new Set();

      sectionBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          sectionBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          currentSection = btn.dataset.section;
          performSearch();
        });
      });

      tagBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const tag = btn.dataset.tag;
          if (activeTags.has(tag)) {
            activeTags.delete(tag);
            btn.classList.remove('active');
          } else {
            activeTags.add(tag);
            btn.classList.add('active');
          }
          performSearch();
        });
      });

      async function performSearch() {
        const query = input.value.trim();
        if (!query) {
          resultsContainer.innerHTML = '<p class="results-hint">Start typing to search...</p>';
          return;
        }

        const filters = {};
        if (currentSection !== 'all') {
          filters.section = [currentSection === 'KB' ? 'Knowledge Base' : currentSection];
        }

        const search = await pagefind.search(query, { filters });
        const results = await Promise.all(search.results.slice(0, 20).map((r) => r.data()));

        const filtered = activeTags.size > 0
          ? results.filter((r) => {
              const meta = r.meta;
              return meta.tag && activeTags.has(meta.tag);
            })
          : results;

        if (filtered.length === 0) {
          resultsContainer.innerHTML = '<p class="results-hint">No results for "' + query + '"</p>';
          return;
        }

        resultsContainer.innerHTML =
          '<p class="results-count">' + filtered.length + ' result' + (filtered.length !== 1 ? 's' : '') + ' for "' + query + '"</p>' +
          filtered.map((r) =>
            '<div class="result-item">' +
              '<a href="' + r.url + '" class="result-title">' + (r.meta.title || r.url) + '</a>' +
              '<p class="result-excerpt">' + r.excerpt + '</p>' +
            '</div>'
          ).join('');
      }

      input.addEventListener('input', performSearch);

      const urlParams = new URLSearchParams(window.location.search);
      const initialQuery = urlParams.get('q');
      if (initialQuery) {
        input.value = initialQuery;
        performSearch();
      }
    }
  </script>
</BaseLayout>

<style>
  .search-page {
    max-width: 600px;
    margin: 0 auto;
    padding: 32px 24px 48px;
  }

  .search-bar {
    margin-bottom: 20px;
  }

  .search-inner {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
  }

  #search-input {
    background: none;
    border: none;
    outline: none;
    color: var(--text-secondary);
    font-size: 14px;
    width: 100%;
    font-family: inherit;
  }

  #search-input::placeholder {
    color: var(--text-dim);
  }

  .filters {
    margin-bottom: 24px;
  }

  .section-filters {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .filter-label {
    font-size: 10px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-right: 4px;
  }

  .filter-btn {
    font-size: 11px;
    padding: 4px 12px;
    border-radius: 4px;
    border: 1px solid rgba(168, 85, 247, 0.2);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .filter-btn:hover {
    border-color: var(--accent);
    color: var(--text-secondary);
  }

  .filter-btn.active {
    background: rgba(168, 85, 247, 0.15);
    border-color: var(--accent);
    color: var(--accent);
  }

  .tag-filters {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tag-filter {
    font-size: 10px;
    color: var(--text-dim);
    border: 1px solid rgba(168, 85, 247, 0.12);
    border-radius: 4px;
    padding: 2px 8px;
    background: transparent;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .tag-filter:hover {
    border-color: rgba(168, 85, 247, 0.3);
    color: var(--text-muted);
  }

  .tag-filter.active {
    background: rgba(168, 85, 247, 0.1);
    border-color: var(--accent);
    color: var(--accent);
  }

  .results-hint {
    color: var(--text-dim);
    font-size: 13px;
  }

  .results-count {
    color: var(--text-dim);
    font-size: 11px;
    margin-bottom: 12px;
  }

  :global(.result-item) {
    padding: 14px 0;
    border-bottom: 1px solid rgba(168, 85, 247, 0.08);
  }

  :global(.result-title) {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  :global(.result-title:hover) {
    color: var(--accent);
  }

  :global(.result-excerpt) {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 6px;
    line-height: 1.5;
  }

  :global(.result-excerpt mark) {
    background: rgba(168, 85, 247, 0.2);
    color: var(--text-secondary);
    padding: 0 2px;
    border-radius: 2px;
  }
</style>
