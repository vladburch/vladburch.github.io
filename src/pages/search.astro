---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const blogPosts = await getCollection('blog');
const kbArticles = await getCollection('kb');

const allTags = new Set<string>();
for (const post of blogPosts) post.data.tags.forEach(t => allTags.add(t));
for (const article of kbArticles) article.data.tags.forEach(t => allTags.add(t));
const sortedTags = Array.from(allTags).sort();

const fallbackIndex = [
  ...blogPosts.map(post => ({
    url: `/blog/${post.id}/`,
    title: post.data.title,
    description: post.data.description,
    section: 'Blog',
    tags: post.data.tags,
  })),
  ...kbArticles.map(article => ({
    url: `/knowledge_base/${article.id}/`,
    title: article.data.title,
    description: article.data.description,
    section: 'Knowledge Base',
    tags: article.data.tags,
  })),
];

---

<BaseLayout title="Search" description="Search articles, tags, and keywords.">
  <section class="search-page">
    <div class="search-bar">
      <div class="gradient-border">
        <div class="gradient-border-inner search-inner">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
          <input
            type="text"
            id="search-input"
            placeholder="Search articles, tags, keywords..."
            autocomplete="off"
          />
        </div>
      </div>
    </div>

    <div class="filters">
      <div class="section-filters">
        <span class="filter-label">Section:</span>
        <button class="filter-btn active" data-section="all">All</button>
        <button class="filter-btn" data-section="Blog">Blog</button>
        <button class="filter-btn" data-section="KB">Knowledge Base</button>
      </div>

      <div class="tag-filters">
        <span class="filter-label">Tags:</span>
        {sortedTags.map(tag => (
          <button class="tag-filter" data-tag={tag}>{tag}</button>
        ))}
      </div>
    </div>

    <div id="search-results" class="results">
      <p class="results-hint">Start typing to search...</p>
    </div>
  </section>

  <script is:inline define:vars={{ fallbackIndex }}>
    window.__searchIndex = fallbackIndex;
  </script>

  <script is:inline type="module">
    (async function() {
      var input = document.getElementById('search-input');
      var resultsContainer = document.getElementById('search-results');
      var sectionBtns = document.querySelectorAll('.filter-btn');
      var tagBtns = document.querySelectorAll('.tag-filter');

      var hasWasm = typeof WebAssembly === 'object';
      var pagefind = null;

      if (hasWasm) {
        try {
          pagefind = await import(new URL('/pagefind/pagefind.js', window.location.origin).href);
          await pagefind.init();
        } catch (e) {
          pagefind = null;
          console.warn('Pagefind unavailable, using fallback search:', e);
        }
      }

      var currentSection = 'all';
      var activeTags = new Set();

      sectionBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          sectionBtns.forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          currentSection = btn.dataset.section;
          performSearch();
        });
      });

      tagBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var tag = btn.dataset.tag;
          if (activeTags.has(tag)) {
            activeTags.delete(tag);
            btn.classList.remove('active');
          } else {
            activeTags.add(tag);
            btn.classList.add('active');
          }
          performSearch();
        });
      });

      function fallbackSearch(query) {
        var index = window.__searchIndex || [];
        var lower = query.toLowerCase();
        var words = lower.split(/\s+/).filter(function(w) { return w.length > 0; });

        var results = [];
        for (var i = 0; i < index.length; i++) {
          var item = index[i];

          if (currentSection !== 'all') {
            var wantSection = currentSection === 'KB' ? 'Knowledge Base' : currentSection;
            if (item.section !== wantSection) continue;
          }

          if (activeTags.size > 0) {
            var hasTag = false;
            for (var t = 0; t < item.tags.length; t++) {
              if (activeTags.has(item.tags[t])) { hasTag = true; break; }
            }
            if (!hasTag) continue;
          }

          var searchable = (item.title + ' ' + item.description + ' ' + item.tags.join(' ')).toLowerCase();
          var matched = true;
          for (var w = 0; w < words.length; w++) {
            if (searchable.indexOf(words[w]) === -1) { matched = false; break; }
          }
          if (matched) {
            var excerpt = item.description;
            for (var w = 0; w < words.length; w++) {
              var re = new RegExp('(' + words[w].replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
              excerpt = excerpt.replace(re, '<mark>$1</mark>');
            }
            results.push({ url: item.url, title: item.title, excerpt: excerpt });
          }
        }
        return results;
      }

      async function performSearch() {
        var query = input.value.trim();
        if (!query) {
          resultsContainer.innerHTML = '<p class="results-hint">Start typing to search...</p>';
          return;
        }

        var filtered;

        if (pagefind) {
          try {
            var searchFilters = {};
            if (currentSection !== 'all') {
              searchFilters.section = [currentSection === 'KB' ? 'Knowledge Base' : currentSection];
            }
            if (activeTags.size > 0) {
              searchFilters.tag = Array.from(activeTags);
            }

            var search = await pagefind.search(query, { filters: searchFilters });
            var data = await Promise.all(search.results.slice(0, 20).map(function(r) { return r.data(); }));

            filtered = data.map(function(r) {
              return { url: r.url, title: r.meta.title || r.url, excerpt: r.excerpt };
            });
          } catch (e) {
            console.warn('Pagefind search failed, falling back:', e);
            filtered = fallbackSearch(query);
          }
        } else {
          filtered = fallbackSearch(query);
        }

        if (filtered.length === 0) {
          resultsContainer.innerHTML = '<p class="results-hint">No results for "' + query + '"</p>';
          return;
        }

        resultsContainer.innerHTML =
          '<p class="results-count">' + filtered.length + ' result' + (filtered.length !== 1 ? 's' : '') + ' for "' + query + '"</p>' +
          filtered.map(function(r) {
            return '<div class="result-item">' +
              '<a href="' + r.url + '" class="result-title">' + r.title + '</a>' +
              '<p class="result-excerpt">' + r.excerpt + '</p>' +
            '</div>';
          }).join('');
      }

      input.addEventListener('input', performSearch);

      var urlParams = new URLSearchParams(window.location.search);
      var initialQuery = urlParams.get('q');
      if (initialQuery) {
        input.value = initialQuery;
        performSearch();
      }
    })();
  </script>
</BaseLayout>

<style>
  .search-page {
    max-width: 600px;
    margin: 0 auto;
    padding: 32px 24px 48px;
  }

  .search-bar {
    margin-bottom: 20px;
  }

  .search-inner {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
  }

  #search-input {
    background: none;
    border: none;
    outline: none;
    color: var(--text-secondary);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    width: 100%;
    letter-spacing: 0.02em;
  }

  #search-input::placeholder {
    color: var(--text-dim);
  }

  .filters {
    margin-bottom: 24px;
  }

  .section-filters {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .filter-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-right: 4px;
  }

  .filter-btn {
    font-size: 11px;
    padding: 4px 12px;
    border-radius: 4px;
    border: 1px solid rgba(14, 165, 233, 0.2);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: 'IBM Plex Mono', monospace;
  }

  .filter-btn:hover {
    border-color: var(--accent);
    color: var(--text-secondary);
  }

  .filter-btn.active {
    background: rgba(14, 165, 233, 0.12);
    border-color: var(--accent);
    color: var(--accent);
  }

  .tag-filters {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tag-filter {
    font-size: 10px;
    color: var(--text-dim);
    border: 1px solid rgba(14, 165, 233, 0.1);
    border-radius: 4px;
    padding: 2px 8px;
    background: transparent;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: 'IBM Plex Mono', monospace;
  }

  .tag-filter:hover {
    border-color: rgba(14, 165, 233, 0.25);
    color: var(--text-muted);
  }

  .tag-filter.active {
    background: rgba(14, 165, 233, 0.08);
    border-color: var(--accent);
    color: var(--accent);
  }

  .results-hint {
    color: var(--text-dim);
    font-size: 13px;
  }

  .results-count {
    color: var(--text-dim);
    font-size: 11px;
    margin-bottom: 12px;
  }

  :global(.result-item) {
    padding: 14px 0;
    border-bottom: 1px solid rgba(14, 165, 233, 0.06);
  }

  :global(.result-title) {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  :global(.result-title:hover) {
    color: var(--accent);
  }

  :global(.result-excerpt) {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 6px;
    line-height: 1.5;
  }

  :global(.result-excerpt mark) {
    background: rgba(14, 165, 233, 0.15);
    color: var(--text-secondary);
    padding: 0 2px;
    border-radius: 2px;
  }

  @media (max-width: 640px) {
    .search-page {
      padding: 24px 16px 40px;
    }
  }
</style>
