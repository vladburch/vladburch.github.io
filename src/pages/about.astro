---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About the author of Firewall Flamingos.">
  <section class="about container">
    <div class="ff-eyebrow" style="margin-bottom:24px">About</div>
    <h1 class="about__h1">
      One researcher.<br />
      <span class="about__ser">A lot of hex.</span>
    </h1>
    <p class="about__lead">
      Firewall Flamingos is a solo threat-intelligence and reverse-engineering publication.
      I disassemble signed drivers, read memory dumps for fun, and spend an unhealthy amount
      of time thinking about how LLMs change offence and defence.
      Everything here is written by me; nothing is sponsored; nothing is generated.
    </p>

    <div class="about__links">
      <a href="https://github.com/vladburch" target="_blank" rel="noopener" class="about__link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
        </svg>
        GitHub · @vladburch
      </a>
      <a href="https://www.linkedin.com/in/vladislav-burtsev/" target="_blank" rel="noopener" class="about__link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z" />
          <rect x="2" y="9" width="4" height="12" />
          <circle cx="4" cy="4" r="2" />
        </svg>
        LinkedIn · Vladislav Burtsev
      </a>
      <a href="mailto:study.white.fox@gmail.com" class="about__link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
          <polyline points="22,6 12,13 2,6" />
        </svg>
        Email
      </a>
    </div>

    <p class="about__pgp">
      PGP D9FF·3BFF·4D3D · Signal on request · no DMs on corporate platforms.
    </p>
  </section>
</BaseLayout>

<style>
  .about {
    padding: 96px 28px;
    max-width: 720px;
  }

  .about__h1 {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: clamp(44px, 7vw, 84px);
    line-height: 1.0;
    letter-spacing: -0.04em;
    margin: 0 0 32px;
    color: var(--fg-1);
  }

  .about__ser {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .about__lead {
    font-size: 19px;
    line-height: 1.55;
    color: var(--fg-1);
    margin-bottom: 40px;
  }

  .about__links {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--border-hair);
  }

  .about__link {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: var(--fs-base);
    color: var(--fg-2);
    padding: 8px 0;
    transition: color var(--dur-fast);
  }

  .about__link:hover { color: var(--fg-1); }

  .about__pgp {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--fg-3);
    letter-spacing: 0.08em;
  }

  @media (max-width: 700px) {
    .about {
      padding: 64px 20px;
    }
  }
</style>
