---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <div class="hero">
    <h1>Firewall Flamingos</h1>
    <p class="subtitle">Security Research & Technical Knowledge</p>
  </div>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 64px 24px;
  }

  .hero h1 {
    font-size: 28px;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .subtitle {
    color: var(--accent);
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
</style>
