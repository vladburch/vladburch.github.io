---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchInput from '../components/SearchInput.astro';
import SectionCard from '../components/SectionCard.astro';
import ArticleList from '../components/ArticleList.astro';
import { getCollection } from 'astro:content';

const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const kbArticles = (await getCollection('kb'))
  .sort((a, b) => b.data.lastUpdated.valueOf() - a.data.lastUpdated.valueOf())
  .slice(0, 4);

const blogItems = blogPosts.map(post => ({
  href: `/blog/${post.id}/`,
  title: post.data.title,
  meta: post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
}));

const kbItems = kbArticles.map(article => ({
  href: `/knowledge_base/${article.id}/`,
  title: article.data.title,
  meta: article.data.tags[0],
}));
---

<BaseLayout title="Home">
  <section class="hero">
    <h1>Firewall Flamingos</h1>
    <p class="subtitle">Security Research <span class="amp">&amp;</span> Technical Knowledge</p>
    <SearchInput />
  </section>

  <section class="sections">
    <SectionCard>
      <div class="section-header">
        <a href="/blog/" class="section-link">Blog -- Latest</a>
        <a href="/blog/" class="view-all">View all &rarr;</a>
      </div>
      <ArticleList items={blogItems} />
    </SectionCard>

    <SectionCard>
      <div class="section-header">
        <a href="/knowledge_base/" class="section-link">Knowledge Base -- Recent</a>
        <a href="/knowledge_base/" class="view-all">View all &rarr;</a>
      </div>
      <ArticleList items={kbItems} />
    </SectionCard>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 72px 24px 48px;
    animation: fade-up 0.6s ease-out both;
  }

  .hero h1 {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 10px;
    line-height: 1.1;
  }

  .subtitle {
    font-family: 'IBM Plex Mono', monospace;
    color: var(--text-dim);
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 32px;
  }

  .amp {
    color: var(--accent);
  }

  .sections {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 8px 32px 56px;
    max-width: 920px;
    margin: 0 auto;
    animation: fade-up 0.6s ease-out 0.15s both;
  }

  .sections > :global(.glow-card) {
    flex: 1;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-subtle);
    font-size: 14px;
  }

  .view-all {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .view-all:hover {
    color: var(--accent);
  }
</style>
