---
import BaseLayout from './BaseLayout.astro';
import TagList from '../components/TagList.astro';
import TableOfContents from '../components/TableOfContents.astro';
import type { MarkdownHeading } from 'astro';
import { getReadingTime } from '../utils/reading-time';

interface Props {
  title: string;
  description: string;
  tags: string[];
  headings: MarkdownHeading[];
  section: 'blog' | 'kb';
  date?: Date;
  category?: string;
  lastUpdated?: Date;
  body: string;
}

const { title, description, tags, headings, section, date, category, lastUpdated, body } = Astro.props;

const readingTime = getReadingTime(body);
const base = import.meta.env.BASE_URL;

const sectionLabel = section === 'blog' ? 'Blog' : 'Knowledge Base';
const sectionHref = `${base}${section === 'blog' ? 'blog' : 'kb'}/`;

const displayDate = date || lastUpdated;
const dateLabel = displayDate
  ? displayDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : '';
---

<BaseLayout title={title} description={description}>
  <article class="article" data-pagefind-body data-pagefind-filter={`section:${sectionLabel}`}>
    <div class="article-header">
      <div class="breadcrumb">
        <a href={sectionHref} class="nav-link">{sectionLabel}</a>
        {category && (
          <>
            <span class="sep">/</span>
            <span>{category}</span>
          </>
        )}
      </div>
      <h1>{title}</h1>
      <div class="article-meta">
        {dateLabel && <span>{dateLabel}</span>}
        <span>{readingTime} min read</span>
      </div>
      <TagList tags={tags} />
    </div>

    <div class="article-body">
      <div class="article-content">
        <slot />
      </div>
      <TableOfContents headings={headings} />
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .article-header {
    padding: 32px 0 24px;
    border-bottom: 1px solid var(--border-subtle);
    margin-bottom: 24px;
  }

  .breadcrumb {
    font-size: 11px;
    color: var(--text-dim);
    margin-bottom: 8px;
  }

  .sep {
    margin: 0 6px;
  }

  .article-header h1 {
    font-size: 24px;
    font-weight: 800;
    line-height: 1.3;
    margin-bottom: 10px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 11px;
    color: var(--text-dim);
    margin-bottom: 12px;
  }

  .article-body {
    display: flex;
    gap: 32px;
    padding-bottom: 48px;
  }

  .article-content {
    flex: 1;
    min-width: 0;
  }

  .article-content :global(h2) {
    font-size: 18px;
    margin: 32px 0 12px;
  }

  .article-content :global(h3) {
    font-size: 15px;
    margin: 24px 0 8px;
  }

  .article-content :global(p) {
    margin-bottom: 16px;
    font-size: 14px;
    color: var(--text-muted);
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 16px;
    padding-left: 24px;
    color: var(--text-muted);
    font-size: 14px;
  }

  .article-content :global(li) {
    margin-bottom: 4px;
  }

  .article-content :global(pre) {
    margin-bottom: 16px;
  }

  .article-content :global(code:not(pre code)) {
    background: rgba(168, 85, 247, 0.1);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 0.9em;
  }

  .article-content :global(img) {
    max-width: 100%;
    border-radius: 6px;
  }
</style>
