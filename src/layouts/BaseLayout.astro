---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Threat Intelligence & Security Research' } = Astro.props;
const siteTitle = `${title} | Firewall Flamingos`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Firewall Flamingos RSS" href="/feed.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{siteTitle}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <div id="cmd-palette" class="cmd" aria-hidden="true" style="display:none">
      <div class="cmd__box">
        <div class="cmd__input">
          <span class="cmd__prompt">›</span>
          <input id="cmd-input" placeholder="search posts, CVEs, hashes…" autocomplete="off" />
          <span class="ff-kbd">ESC</span>
        </div>
        <div class="cmd__body" id="cmd-body">
          <div class="cmd__group">
            <div class="cmd__glabel">Navigate</div>
            <a class="cmd__item" href="/">
              <span>Home</span><span class="cmd__meta">/</span>
            </a>
            <a class="cmd__item" href="/blog/">
              <span>Blog archive</span><span class="cmd__meta">/blog/</span>
            </a>
            <a class="cmd__item" href="/knowledge_base/">
              <span>Knowledge Base</span><span class="cmd__meta">/knowledge_base/</span>
            </a>
            <a class="cmd__item" href="/about/">
              <span>About</span><span class="cmd__meta">/about/</span>
            </a>
          </div>
          <div class="cmd__group">
            <div class="cmd__glabel">Search</div>
            <a class="cmd__item" id="cmd-search-link" href="/search/">
              <span id="cmd-search-label">Search the site</span>
              <span class="cmd__meta">↵</span>
            </a>
          </div>
        </div>
        <div class="cmd__foot">
          <span>↑↓ navigate</span>
          <span>↵ open</span>
          <span class="ff-live-dot"></span>
          <span>SIG · LIVE</span>
        </div>
      </div>
    </div>
  </body>
</html>

<script>
  const palette = document.getElementById('cmd-palette') as HTMLElement;
  const input = document.getElementById('cmd-input') as HTMLInputElement;
  const searchLink = document.getElementById('cmd-search-link') as HTMLAnchorElement;
  const searchLabel = document.getElementById('cmd-search-label') as HTMLElement;

  function open() {
    palette.style.display = 'flex';
    palette.setAttribute('aria-hidden', 'false');
    input.value = '';
    input.focus();
  }
  function close() {
    palette.style.display = 'none';
    palette.setAttribute('aria-hidden', 'true');
  }

  document.addEventListener('keydown', e => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      palette.style.display === 'none' ? open() : close();
    }
    if (e.key === 'Escape') close();
  });

  palette.addEventListener('click', e => {
    if (e.target === palette) close();
  });

  input.addEventListener('input', () => {
    const q = input.value.trim();
    if (q) {
      searchLink.href = `/search/?q=${encodeURIComponent(q)}`;
      searchLabel.textContent = `Search for "${q}"`;
    } else {
      searchLink.href = '/search/';
      searchLabel.textContent = 'Search the site';
    }
  });

  document.querySelectorAll('[data-cmd-open]').forEach(el => {
    el.addEventListener('click', e => { e.preventDefault(); open(); });
  });
</script>

<style is:global>
  .cmd {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(10,10,11,0.55);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12vh;
    animation: cmd-fadein 0.15s var(--ease-out);
  }

  @keyframes cmd-fadein {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .cmd__box {
    width: min(620px, 92vw);
    background: var(--bg-1);
    border: 1px solid var(--border-1);
    border-radius: var(--r-3);
    box-shadow: 0 24px 60px rgba(0,0,0,0.22);
    overflow: hidden;
  }

  .cmd__input {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border-hair);
  }

  .cmd__prompt {
    color: var(--fg-3);
    font-family: var(--font-mono);
    font-size: 16px;
  }

  .cmd__input input {
    flex: 1;
    border: 0;
    outline: none;
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--fg-1);
    background: transparent;
  }

  .cmd__body {
    max-height: 50vh;
    overflow: auto;
    padding: 8px 0;
  }

  .cmd__group { padding: 8px 12px; }

  .cmd__glabel {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-3);
    padding: 4px 6px 8px;
  }

  .cmd__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 10px;
    border-radius: var(--r-2);
    font-size: 14px;
    cursor: pointer;
    color: var(--fg-1);
    transition: background var(--dur-fast);
  }

  .cmd__item:hover { background: var(--bg-2); }

  .cmd__meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.1em;
  }

  .cmd__foot {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 16px;
    border-top: 1px solid var(--border-hair);
    background: var(--bg-2);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.08em;
  }
</style>
